# ---- Servidor ----
PORT=3001
# Origens permitidas para o frontend (separadas por vírgula).
# Em produção, inclua a URL do frontend na Vercel (ex: https://cardapio.vercel.app).
CORS_ORIGINS=http://localhost:3000

# ---- Banco de dados (PostgreSQL — Supabase) ----
# Use a Connection String do Supabase → Connect / Project Settings → Database.
# Escolha a "Session pooler" (porta 5432): é IPv4 e suporta as migrations do
# Prisma. NÃO use a "Transaction pooler" (6543) — ela é para serverless e quebra
# `prisma migrate deploy` sem um directUrl separado (que este schema não tem).
# Troque <ref>/<senha> e mantenha sslmode=require. O host pode ser aws-0 ou aws-1.
#   DATABASE_URL="postgresql://postgres.<ref>:<senha>@aws-1-<regiao>.pooler.supabase.com:5432/postgres?sslmode=require"
# Dev local: um Postgres local também funciona.
DATABASE_URL="postgresql://postgres.<ref>:<senha>@aws-1-sa-east-1.pooler.supabase.com:5432/postgres?sslmode=require"

# ---- Fila de pedidos (Redis + BullMQ) ----
# Redis roda LOCAL no PC do caixa (nativo). O código usa host/porta abaixo.
# (REDIS_URL com rediss:// também é suportado, caso um dia use Redis em nuvem.)
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- Impressão ----
# O backend roda no PC do caixa e faz tudo (API + fila + impressão), então
# deixe PRINT_WORKER=on em produção. Em dev, deixe off se não quiser o worker.
PRINT_WORKER=on

# ---- Impressoras térmicas (ESC/POS) — usadas quando PRINT_WORKER=on ----
# Tipo de conexão e endereço. Deixe vazio para desativar a impressão (modo dev).
# Exemplos de interface: "tcp://192.168.0.50" (IP na rede) ou "printer:auto" / "//localhost/NomeDaImpressora" (USB/Windows)
PRINTER_CASHIER_INTERFACE=
PRINTER_KITCHEN_INTERFACE=
# Largura em caracteres do papel (58mm ~ 32, 80mm ~ 48)
PRINTER_WIDTH=48
