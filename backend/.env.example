# ---- Servidor ----
# Local usa 3001; na Fly.io o fly.toml define PORT=8080.
PORT=3001
# Origens permitidas para o frontend (separadas por vírgula).
# Em produção, inclua a URL do frontend na Vercel (ex: https://cardapio.vercel.app).
CORS_ORIGINS=http://localhost:3000

# ---- Banco de dados (PostgreSQL) ----
# Local: PostgreSQL no notebook. Nuvem: string do provedor gerenciado
# (ex: Neon/Supabase/Fly Postgres). Use sslmode=require em nuvem.
DATABASE_URL="postgresql://bacalhau:bacalhau@localhost:5432/bacalhau?schema=public"

# ---- Fila de pedidos (Redis + BullMQ) ----
# Nuvem (Upstash/Fly Redis): defina REDIS_URL. Use rediss:// para TLS.
#   REDIS_URL="rediss://default:senha@host:6379"
# Local/dev: se REDIS_URL não estiver definido, cai para host/porta abaixo.
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- Impressão ----
# PRINT_WORKER=on ativa o worker que consome a fila e imprime. Ligue APENAS no
# agente local (PC do caixa, na mesma rede das impressoras). No backend da
# nuvem (Fly.io) deixe desligado: ele só enfileira os pedidos.
PRINT_WORKER=off

# ---- Impressoras térmicas (ESC/POS) — usadas só quando PRINT_WORKER=on ----
# Tipo de conexão e endereço. Deixe vazio para desativar a impressão (modo dev).
# Exemplos de interface: "tcp://192.168.0.50" (IP na rede) ou "printer:auto" / "//localhost/NomeDaImpressora" (USB/Windows)
PRINTER_CASHIER_INTERFACE=
PRINTER_KITCHEN_INTERFACE=
# Largura em caracteres do papel (58mm ~ 32, 80mm ~ 48)
PRINTER_WIDTH=48
