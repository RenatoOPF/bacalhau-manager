# ==========================================================================
# BACKEND NA NUVEM (VM Oracle Cloud) — API + WebSocket, ENFILEIRA os pedidos.
# Não imprime (a impressão fica no PC do caixa). Ver docs/deploy-cloud.md.
# Copie para backend/.env na VM e preencha.
# ==========================================================================

# ---- Servidor ----
PORT=3001
# URL do frontend na Vercel (separe múltiplas por vírgula).
CORS_ORIGINS=https://SEU-PROJETO.vercel.app

# ---- Banco de dados (PostgreSQL — Supabase) ----
# Session pooler (porta 5432). Troque <ref>/<senha> e mantenha sslmode=require.
DATABASE_URL="postgresql://postgres.<ref>:<senha>@aws-1-sa-east-1.pooler.supabase.com:5432/postgres?sslmode=require"

# ---- Fila de pedidos (Redis — Upstash) ----
# Copie a "Redis URL" (rediss://) do console do Upstash. O TLS liga sozinho
# com rediss://. O MESMO valor vai no .env do PC do caixa (agente).
REDIS_URL=rediss://default:<senha>@<endpoint>.upstash.io:6379

# ---- Autenticação ----
# Só a API (nuvem) usa JWT; o agente do caixa não precisa deste valor.
# Use algo longo e aleatório e mantenha em segredo.
JWT_SECRET=troque-por-um-segredo-forte-e-aleatorio
# Admin inicial criado no seed (troque a senha após o primeiro login).
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=UmaSenhaForte123

# ---- Impressão ----
# Desligada na nuvem: a VM não alcança as térmicas locais do caixa.
PRINT_WORKER=off
