// Schema do banco — Fase 1 / MVP (Bacalhau & Cia)
// Cobre: cardápio, pedidos (com itens) e pagamento manual (dinheiro/PIX).
// iFood/Gami, estoque, caixa e funcionários entram em fases futuras.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Funcionários / acesso ----------

enum Role {
  ADMIN // gerente com acesso total (inclui gestão de funcionários)
  MANAGER // opera fila, caixa, cardápio e relatórios
  KITCHEN // cozinheiro (cadastro; sem login no MVP)
  DELIVERY // entregador (cadastro; base para taxa de entrega)
}

model Employee {
  id           String   @id @default(cuid())
  name         String
  username     String   @unique
  passwordHash String
  role         Role     @default(MANAGER)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ---------- Cardápio ----------

model MenuCategory {
  id        String     @id @default(cuid())
  name      String
  sortOrder Int        @default(0)
  active    Boolean    @default(true)
  items     MenuItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model MenuItem {
  id          String       @id @default(cuid())
  category    MenuCategory @relation(fields: [categoryId], references: [id])
  categoryId  String
  name        String
  description String?
  // Preço em centavos para evitar imprecisão de ponto flutuante.
  // Usado quando o item NÃO tem opções; com opções, o preço vem da opção.
  priceCents  Int
  available   Boolean          @default(true)
  // Ordem de exibição dentro da categoria (empate resolvido pelo nome).
  sortOrder   Int              @default(0)
  options     MenuItemOption[]
  orderItems  OrderItem[]

  // Insumo consumido pelo prato (estoque em porções). SetNull: excluir o
  // insumo não apaga o prato. Nos itens COM opções, o vínculo da opção
  // (se houver) tem prioridade sobre este.
  stockItem      StockItem? @relation(fields: [stockItemId], references: [id], onDelete: SetNull)
  stockItemId    String?
  // Consumo em meias porções por unidade vendida quando o item NÃO tem
  // opções (2 = 1 porção; executivos = 1). Com opções, o consumo vem do
  // nome da opção (Meia = 1, Inteira = 2).
  stockHalfUnits Int        @default(2)

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([categoryId])
}

/// Variações de um item com preço próprio (ex.: Individual/Inteira, ou
/// Tilápia Individual/Salmão Inteira nos peixes). Quando um item tem opções,
/// o cliente escolhe uma e o preço vem dela.
model MenuItemOption {
  id         String   @id @default(cuid())
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  menuItemId String
  name       String
  priceCents Int
  sortOrder  Int      @default(0)
  available  Boolean  @default(true)

  // Insumo da opção — necessário quando a proteína varia por opção
  // (ex.: Tilápia/Sirigado/Salmão). Se nulo, vale o insumo do item.
  stockItem   StockItem? @relation(fields: [stockItemId], references: [id], onDelete: SetNull)
  stockItemId String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([menuItemId])
}

// ---------- Estoque (por porções) ----------

/// Insumo controlado por porções (ex.: "Bacalhau em Posta", "Camarão",
/// "Tilápia"). O saldo é guardado em MEIAS porções (halfUnits) para não ter
/// fração no banco: Meia Porção desconta 1, Porção Inteira desconta 2.
/// Estoque pode ficar negativo — zerado só alerta no admin, não bloqueia venda.
model StockItem {
  id        String  @id @default(cuid())
  name      String  @unique
  // Saldo em meias porções (2 = 1 porção).
  halfUnits Int     @default(0)
  // Alerta no admin quando halfUnits <= alertHalfUnits.
  alertHalfUnits Int @default(4)
  active    Boolean @default(true)
  sortOrder Int     @default(0)

  menuItems MenuItem[]
  options   MenuItemOption[]
  movements StockMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Movimentação de estoque (venda, estorno, reposição, ajuste). Permite
/// auditar o saldo e estornar pedidos cancelados/excluídos de forma
/// idempotente (o estorno zera o saldo líquido dos movimentos do pedido).
model StockMovement {
  id          String    @id @default(cuid())
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  stockItemId String
  // Em meias porções; negativo = saída (venda), positivo = entrada/estorno.
  deltaHalfUnits Int
  reason      String
  // Pedido que originou o movimento (venda/estorno); nulo em ajustes manuais.
  orderId     String?
  createdAt   DateTime  @default(now())

  @@index([stockItemId])
  @@index([orderId])
}

// ---------- Pedidos ----------

enum OrderChannel {
  OWN // cardápio próprio
  IFOOD // capturado via impressora fake
  NOVENTA_NOVE // 99Food, capturado via impressora fake
  GAMI // futuro
}

enum OrderStatus {
  RECEIVED // Recebido
  IN_PREPARATION // Em preparo
  READY // Pronto
  OUT_FOR_DELIVERY // Saiu para entrega
  DELIVERED // Entregue
  CANCELED // Cancelado
}

enum PaymentMethod {
  CASH // dinheiro
  PIX // PIX
  ONLINE // pago no app (iFood/99) — não entra no fechamento de caixa
}

enum PaymentStatus {
  PENDING
  PAID
}

model Order {
  id       String @id @default(cuid())
  // Id global único — usado no link de acompanhamento e internamente.
  protocol Int    @unique @default(autoincrement())
  // Número exibido ao cliente/cozinha/caixa, reinicia a cada dia ou ao fechar o caixa (via DailyCounter).
  dailyNumber Int  @default(0)

  channel OrderChannel @default(OWN)
  status  OrderStatus  @default(RECEIVED)

  // Referência do pedido no canal externo (Localizador do iFood / código da 99).
  // Único por canal para evitar duplicar ao reimprimir a mesma comanda.
  externalId String?

  customerName  String
  customerPhone String?

  // Endereço de entrega — visível apenas no caixa, nunca no ticket da cozinha.
  addressStreet       String
  addressNumber       String?
  addressComplement   String?
  addressNeighborhood String?
  addressReference    String?

  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PENDING)
  // Momento em que o pagamento foi registrado no caixa (base do fechamento diário).
  paidAt        DateTime?

  // Total em centavos. Para pedidos externos inclui a taxa de entrega abaixo.
  totalCents Int    @default(0)
  // Taxa de entrega (iFood/99), já inclusa no totalCents. 0 nos pedidos próprios.
  deliveryFeeCents Int @default(0)
  notes      String?

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([channel, externalId])
  @@index([status])
  @@index([createdAt])
  @@index([paidAt])
}

model OrderItem {
  id      String @id @default(cuid())
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String

  // Opcional + SetNull: permite excluir o item do cardápio sem apagar o
  // histórico do pedido (os snapshots abaixo preservam nome/preço/opção).
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  menuItemId String?

  // Snapshots para preservar o histórico mesmo se o cardápio mudar depois.
  nameSnapshot       String
  optionNameSnapshot String? // opção escolhida (ex.: "Inteira"), se o item tiver
  priceCents         Int
  quantity           Int     @default(1)
  notes              String?

  @@index([orderId])
}

// ---------- Arquivo do sistema antigo ----------

/// Pedidos históricos importados do sistema anterior (2023–2026). Só totais,
/// sem itens nem endereço. Isolado do fluxo operacional (model Order) para não
/// poluir o caixa nem os relatórios do dia a dia — serve apenas para consulta.
model LegacyOrder {
  id           String    @id @default(cuid())
  code         String    @unique // "Código" do sistema antigo
  openedAt     DateTime // Data de abertura
  closedAt     DateTime? // Data de fechamento
  status       String? // texto original (ex.: "Finalizado - Pago")
  createdBy    String? // "Criado por"
  customerName String? // "Cliente"
  type         String? // "Tipo" (ex.: Delivery)
  channel      String? // "Origem" (iFood, Desktop, 99Food, ...)
  totalCents   Int       @default(0)
  importedAt   DateTime  @default(now())

  @@index([openedAt])
}

/// Contador diário do número de pedido (reinicia por dia). A chave é o dia
/// local "YYYY-MM-DD" e lastNumber é o último número emitido naquele dia.
model DailyCounter {
  date       String @id
  lastNumber Int    @default(0)
}
