# ==========================================================================
# AGENTE DE IMPRESSÃO — PC do caixa (Windows). Roda SÓ o worker (dist/worker.js):
# consome a fila e imprime nas térmicas locais. Sem API, sem túnel (só saída).
# Copie para backend/.env no PC do caixa e preencha. Ver docs/deploy-windows.md.
# ==========================================================================

# ---- Banco de dados (PostgreSQL — Supabase) ----
# MESMO valor do backend na nuvem: o worker lê o pedido para montar o ticket.
DATABASE_URL="postgresql://postgres.<ref>:<senha>@aws-1-sa-east-1.pooler.supabase.com:5432/postgres?sslmode=require"

# ---- Fila de pedidos (Redis — Upstash) ----
# MESMO valor (rediss://) do backend na nuvem — é a fila compartilhada.
REDIS_URL=rediss://default:<senha>@<endpoint>.upstash.io:6379

# ---- Impressoras térmicas (ESC/POS) ----
# Deixe vazio para simular a impressão (só loga) enquanto testa.
# Exemplos: "//localhost/Caixa" (compartilhamento USB/Windows) ou
#           "tcp://192.168.0.50" (impressora com IP na rede local).
PRINTER_CASHIER_INTERFACE=//localhost/Caixa
PRINTER_KITCHEN_INTERFACE=//localhost/Cozinha
# Largura em caracteres do papel (58mm ~ 32, 80mm ~ 48).
PRINTER_WIDTH=48

# ---- Captura iFood/99 ("impressora fake") ----
# Porta TCP onde o agente recebe as impressões do iFood/99. Crie no Windows uma
# impressora com Standard TCP/IP Port -> 127.0.0.1 nesta porta (RAW), aponte o
# app do iFood/99 para ela. Deixe vazio para desativar a captura.
CAPTURE_PORT=9100
# Onde salvar as amostras capturadas (padrão: ./captures na pasta do backend).
CAPTURE_DIR=
# API na nuvem para onde a captura é enviada (vira pedido) + a MESMA chave da VM.
# Deixe INTEGRATION_URL vazio para só arquivar as amostras, sem criar pedido.
INTEGRATION_URL=https://137.131.162.0.sslip.io/api
INTEGRATION_KEY=
